        "arch": {
          "type": "string"
        },
        "runtime": {
          "type": "string",
          "enum": [
            "node",
            "daemon-py"
          ]
        },
        "isCi": {
          "type": "boolean"
        }
      },
      "required": [
        "cliVersion",
        "nodeVersion",
